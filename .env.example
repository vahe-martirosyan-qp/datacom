# PostgreSQL (optional). When set, CMS reads/writes only PostgreSQL; data/content-store.json is
# not loaded on startup (only used if DB is unset, or as fallback if the DB is unreachable).
# Local Docker: `docker compose up -d` then:
# DATABASE_URL=postgresql://datacom:datacom@localhost:5433/datacom?schema=public
# Schema: `pnpm db:deploy` applies `prisma/migrations` (also runs on Vercel via `vercel-build`).
# First content import: `pnpm db:import` (pushes seeds + optional data/*.json into the DB).

# JWT (use long random strings in production, min 32 chars)
JWT_SECRET=change-me-use-at-least-32-characters-secret
JWT_REFRESH_SECRET=change-me-another-32-chars-refresh-secret

# Admin credentials (stub backend)
ADMIN_LOGIN=datacom
ADMIN_PASSWORD=12345678

# Set to 1 to log CMS homepage/project payload in the browser console (also on in NODE_ENV=development).
# NEXT_PUBLIC_CMS_DEBUG=1

# Optional: hide homepage/project CMS console.info logs in the browser
# NEXT_PUBLIC_CMS_SILENCE_CMS_LOGS=1

# Vercel Blob — required on Vercel for /api/admin/upload (Storage → Blob → token).
# Local dev: omit; files go to public/uploads/
# BLOB_READ_WRITE_TOKEN=
