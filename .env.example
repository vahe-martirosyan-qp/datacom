# PostgreSQL (optional). When set, CMS reads/writes only PostgreSQL; data/content-store.json is
# not loaded on startup (only used if DB is unset, or as fallback if the DB is unreachable).
# Local Docker: `docker compose up -d` then:
# DATABASE_URL=postgresql://datacom:datacom@localhost:5433/datacom?schema=public
# First import: `pnpm db:import` (pushes schema + seeds + optional data/*.json into the DB).

# JWT (use long random strings in production, min 32 chars)
JWT_SECRET=change-me-use-at-least-32-characters-secret
JWT_REFRESH_SECRET=change-me-another-32-chars-refresh-secret

# Admin credentials (stub backend)
ADMIN_LOGIN=datacom
ADMIN_PASSWORD=12345678
